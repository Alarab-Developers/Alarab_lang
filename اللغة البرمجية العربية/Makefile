فهم_اللغة/ألاوامر_الأساسة/خروج/خروج.c \
فهم_اللغة/ألاوامر_الأساسة/حل/حل.c \
فهم_اللغة/ألاوامر_الأساسة/احسب/احسب.c \
فهم_اللغة/الدوال_والشروط/الدالة/الدالة.c \
فهم_اللغة/الدوال_والشروط/الشرط/الشرط.c \
فهم_اللغة/الحلقات_التكرارية/الحلقات_التكرارية.c \
