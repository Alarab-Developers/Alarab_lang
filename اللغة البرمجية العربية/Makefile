# =========================
# اسم البرنامج
# =========================
TARGET = اللغة

# =========================
# المترجم
# =========================
CC = gcc

# =========================
# خيارات الترجمة
# =========================
CFLAGS = -Wall -Wextra -O2

# =========================
# مسارات الرؤوس (Headers)
# =========================
INCLUDES = \
-Iالتنفيذ \
-Iالمحرك \
-Iفهم_اللغة \
-Iنظامي \
-Iالقاموس \
-Iالمحرك_الرياضي \
