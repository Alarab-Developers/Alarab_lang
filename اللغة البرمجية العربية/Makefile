فهم_اللغة/مفسر_العمليات.c \
محرك_كشف_الأخطاء/محرك_كشف_الأخطاء.c \
محرك_كشف_الأخطاء/أدوات/أدوات_الكشف.c \
فهم_اللغة/ألاوامر_الأساسة/اطبع/اطبع.c \
