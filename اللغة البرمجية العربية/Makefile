# =========================
# الهدف الافتراضي
# =========================
all:
	$(CC) $(CFLAGS) $(SOURCES) $(INCLUDES) -lm -o $(TARGET)

# =========================
# تشغيل البرنامج
# =========================
run: all
	./$(TARGET)

# =========================
# تنظيف
# =========================
clean:
	rm -f $(TARGET)
